<Window x:Class="StretchCord.UI.TransmissionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="StretchCord — Stream Window"
        Width="1280" Height="720"
        MinWidth="640" MinHeight="360"
        Background="Black"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        SizeToContent="Manual">

    <Window.Resources>
        <Style TargetType="Image" x:Key="StretchedPreview">
            <Setter Property="Stretch" Value="Fill"/>
            <Setter Property="RenderOptions.BitmapScalingMode" Value="HighQuality"/>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- The main stretched video area -->
        <Image x:Name="PreviewImage"
               Style="{StaticResource StretchedPreview}"
               HorizontalAlignment="Stretch"
               VerticalAlignment="Stretch"/>

        <!-- Overlay controls (auto-hide) -->
        <Grid x:Name="OverlayPanel"
              VerticalAlignment="Bottom"
              HorizontalAlignment="Stretch"
              Opacity="0.85">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="Transparent" Offset="0"/>
                    <GradientStop Color="#CC000000" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="12,8">
                <Button x:Name="BtnToggleControls"
                        Content="Hide Controls"
                        Click="BtnToggleControls_Click"
                        Padding="8,4" Margin="4,0"
                        Background="#33FFFFFF" Foreground="White"
                        BorderBrush="#66FFFFFF"/>
                <Button x:Name="BtnFullscreen"
                        Content="⛶ Fullscreen"
                        Click="BtnFullscreen_Click"
                        Padding="8,4" Margin="4,0"
                        Background="#33FFFFFF" Foreground="White"
                        BorderBrush="#66FFFFFF"/>
            </StackPanel>
        </Grid>

        <!-- No source label -->
        <TextBlock x:Name="NoSourceLabel"
                   Text="No video source active.&#10;Start video capture in the main window."
                   Foreground="#88FFFFFF"
                   FontSize="18"
                   TextAlignment="Center"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Visibility="Visible"/>
    </Grid>
</Window>
